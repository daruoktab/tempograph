# .env.example  →  copy ke ``.env`` (lokal, tidak di-commit) dan isi nilai asli.
#
# Menjalankan SurrealDB + skrip lain dari root repo tanpa ``surreal start`` manual:
#   python scripts/run_with_local_surreal.py -- python scripts/test_surreal_connection.py

# =============================================================================
# REQUIRED: LLM API Keys
# =============================================================================

# Google Gemini API Key (required)
GEMINI_API_KEY=your-gemini-api-key-here

# Novita AI API Key (optional, for Gemma models)
NOVITAAI_API_KEY=your-novita-api-key-here

# =============================================================================
# Single stack (scripts: --setup env + load_eval_env / get_agentic_*_from_env)
# =============================================================================
# LLM untuk ekstraksi fakta (agentic): gemini | novita (huggingface belum didukung)
LLM_PROVIDER=gemini
# Contoh: gemini-2.5-flash ; Novita/OpenAI-compat: google/gemma-3-27b-it
LLM_MODEL=

# Embedding untuk session_passage + fakta: gemini | huggingface
EMBED_PROVIDER=gemini
# Contoh: gemini-embedding-001 ; lokal: google/embeddinggemma-300m
EMBED_MODEL=

# Partisi Surreal: graph agentic (group_id) & dense vanilla (collection logis)
RAG_GROUP_ID=agentic_default
RAG_SESSION_COLLECTION=vanilla_default

# Hanya untuk ``python scripts/evaluate_agentic.py --setup env``
# agentic | vanilla | hybrid
RAG_MODE=agentic

# =============================================================================
# Dataset generation (``python src/dataset/generator.py``) — Gemini IDs
# Tiga tier: structured (JSON/persona/events), dialog (sesi panjang + cache),
# light (ringkasan, ground truth, merge konflik). Kosong = default di kode.
# =============================================================================
DATASET_GEMINI_MODEL_STRUCTURED=gemini-2.5-flash
DATASET_GEMINI_MODEL_DIALOG=gemini-2.5-pro
DATASET_GEMINI_MODEL_LIGHT=gemini-2.5-flash-lite

# =============================================================================
# REQUIRED: SurrealDB (graph + vectors; Vanilla + Agentic)
# =============================================================================

# Tanpa /rpc — SDK Python surrealdb menambahkan /rpc sendiri.
# HTTP 404 saat connect: biasanya bukan SurrealDB di port itu, atau URL salah.
SURREAL_URL=ws://127.0.0.1:8000
SURREAL_USER=root
SURREAL_PASS=root
# Namespace = batas proyek; database = partisi logis (boleh beda per lingkungan: main, staging, …).
SURREAL_NS=tempograph
SURREAL_DB=main

# Opsional: path ke binary SurrealDB CLI jika tidak ada di PATH (contoh: C:\Tools\surreal.exe)
# SURREAL_CLI=

# Opsional: argumen storage untuk ``surreal start`` (default di launcher: SurrealKV ``data/surreal_local``).
# Contoh: SURREAL_START_PATH=memory  (hanya RAM), atau surrealkv://path/relatif-dari-repo-root
# SURREAL_START_PATH=

# =============================================================================
# OPTIONAL: OpenRouter (alternative LLM provider)
# =============================================================================

OPENROUTER_API_KEY=
